#!/bin/sh
#
# Pre-commit hook: run script tests and check dashboard bundle freshness.

if ! bash tests/test-scripts.sh; then
  echo ""
  echo "ERROR: Script tests failed. Fix the issues before committing."
  exit 1
fi

# Lint & format check dashboard source if any dashboard files are staged
DASHBOARD_TS_CHANGED=$(git diff --cached --name-only -- tools/dev-dashboard/src/ | head -1)
if [ -n "$DASHBOARD_TS_CHANGED" ]; then
  echo "Running dashboard lint & format check..."
  if ! (cd tools/dev-dashboard && npx eslint src/ && npx prettier --check src/); then
    echo ""
    echo "ERROR: Dashboard lint/format issues. Run 'cd tools/dev-dashboard && npm run lint:fix && npm run format' to fix."
    exit 1
  fi
fi

# Check if dashboard source changed without rebuilding the bundle
DASHBOARD_SRC_CHANGED=$(git diff --cached --name-only -- tools/dev-dashboard/src/ tools/dev-dashboard/package.json | head -1)
BUNDLE_CHANGED=$(git diff --cached --name-only -- plugins/dev-workflow/skills/dev-dashboard/dashboard/ | head -1)

if [ -n "$DASHBOARD_SRC_CHANGED" ] && [ -z "$BUNDLE_CHANGED" ]; then
  echo ""
  echo "ERROR: Dashboard source files changed but bundle was not updated."
  echo "Run 'cd tools/dev-dashboard && npm run bundle' and stage the output."
  exit 1
fi

# Check if CLI source changed without rebuilding the bundle
CLI_SRC_CHANGED=$(git diff --cached --name-only -- tools/dev-workflow-cli/src/ tools/dev-workflow-core/src/ tools/dev-workflow-cli/package.json | head -1)
CLI_BUNDLE_CHANGED=$(git diff --cached --name-only -- plugins/dev-workflow/bin/dev-workflow.cjs | head -1)

if [ -n "$CLI_SRC_CHANGED" ] && [ -z "$CLI_BUNDLE_CHANGED" ]; then
  echo ""
  echo "ERROR: CLI source files changed but bundle was not updated."
  echo "Run 'cd tools/dev-workflow-cli && npm run bundle' and stage the output."
  exit 1
fi
