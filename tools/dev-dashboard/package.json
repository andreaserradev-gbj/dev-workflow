{
  "name": "dev-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tsx watch src/server/index.ts\" \"npx vite\"",
    "build": "vite build && tsc --project tsconfig.server.json",
    "bundle": "npm run build && node scripts/bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "chokidar": "^4.0.0",
    "dev-workflow-core": "file:../dev-workflow-core",
    "fast-glob": "^3.3.0",
    "fastify": "^5.0.0",
    "gray-matter": "^4.0.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.9.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "preact": "^10.24.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
