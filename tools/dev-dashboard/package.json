{
  "name": "dev-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx tsx watch src/server/index.ts\" \"npx vite\"",
    "build": "vite build && tsc --project tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "fast-glob": "^3.3.0",
    "fastify": "^5.0.0",
    "@fastify/static": "^8.0.0",
    "gray-matter": "^4.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.0",
    "concurrently": "^9.0.0",
    "preact": "^10.24.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0"
  }
}
